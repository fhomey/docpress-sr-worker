FROM runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

WORKDIR /app

# Install dependencies
COPY requirements_sr.txt .
RUN pip install -r requirements_sr.txt -q

# Pre-download Real-ESRGAN weights at build time
# (so first request doesn't wait for download)
RUN wget -q -O /tmp/RealESRGAN_x4plus.pth \
    https://github.com/xinntao/Real-ESRGAN/releases/download/v0.1.0/RealESRGAN_x4plus.pth

# Copy handler
COPY sr_worker.py .

CMD ["python", "-u", "sr_worker.py"]
